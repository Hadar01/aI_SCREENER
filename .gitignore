# Root-level gitignore
# ── Secrets ────────────────────────────────────────────────────────────────
**/.env
**/.env.local
**/.env.*.local

# ── Dependencies ────────────────────────────────────────────────────────────
**/node_modules/

# ── Build Output ────────────────────────────────────────────────────────────
client/dist/

# ── Uploads (user files, never commit) ─────────────────────────────────────
server/uploads/

# ── Logs ────────────────────────────────────────────────────────────────────
**/*.log
**/npm-debug.log*

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
